{
    // See https://www.typescriptlang.org/tsconfig for reference.
    "compilerOptions": {
        "outDir": "./dist", 
        "allowJs": true,
        "baseUrl": "./",
        "target": "es6",
        "sourceMap": true,
        "noEmitOnError": true,
        "noImplicitAny": true,
        // https://www.typescriptlang.org/tsconfig#module. "CommonJS" is adviced
        // but I'm only interested in a working build.
        "module": "CommonJS",
        "moduleResolution": "node"
    },
    "include": [
        "./src/**/*"
    ]
}
