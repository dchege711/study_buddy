CREATE TABLE IF NOT EXISTS "FlashCards" ("id" UUID,
"title" VARCHAR(255) NOT NULL,
"rawDescription" TEXT NOT NULL,
"htmlDescription" TEXT NOT NULL,
"urgency" DECIMAL NOT NULL,
"isPublic" BOOLEAN NOT NULL,
"trashedTimestamp" TIMESTAMP WITH TIME ZONE,
"numTimesFlaggedAsDuplicate" INTEGER NOT NULL DEFAULT 0,
"numTimesFlaggedForReview" INTEGER NOT NULL DEFAULT 0,
"createdAt" TIMESTAMP WITH TIME ZONE NOT NULL,
"updatedAt" TIMESTAMP WITH TIME ZONE NOT NULL,
"ownerId" UUID REFERENCES "Users" ("id") ON DELETE SET NULL ON UPDATE CASCADE,
"FlashCardId" UUID REFERENCES "FlashCards" ("id") ON DELETE SET NULL ON UPDATE CASCADE,
"parentId" UUID REFERENCES "FlashCards" ("id") ON DELETE SET NULL ON UPDATE CASCADE,
"ReviewStreakId" UUID REFERENCES "ReviewStreaks" ("id") ON DELETE SET NULL ON UPDATE CASCADE,
PRIMARY KEY ("id"))
------------------------------------
SELECT i.relname AS name,
ix.indisprimary AS primary,
ix.indisunique AS unique,
ix.indkey AS indkey,
array_agg(a.attnum) as column_indexes,
array_agg(a.attname) AS column_names,
pg_get_indexdef(ix.indexrelid) AS definition FROM pg_class t,
pg_class i,
pg_index ix,
pg_attribute a WHERE t.oid = ix.indrelid AND i.oid = ix.indexrelid AND a.attrelid = t.oid AND t.relkind = 'r' and t.relname = 'FlashCards' GROUP BY i.relname,
ix.indexrelid,
ix.indisprimary,
ix.indisunique,
ix.indkey ORDER BY i.relname
------------------------------------
