CREATE TABLE IF NOT EXISTS "FlashCardTag" ("createdAt" TIMESTAMP WITH TIME ZONE NOT NULL,
"updatedAt" TIMESTAMP WITH TIME ZONE NOT NULL,
"TagId" UUID  REFERENCES "Tags" ("id") ON DELETE CASCADE ON UPDATE CASCADE,
"FlashCardId" UUID  REFERENCES "FlashCards" ("id") ON DELETE CASCADE ON UPDATE CASCADE,
PRIMARY KEY ("TagId",
"FlashCardId"))
------------------------------------
