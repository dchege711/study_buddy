{
  "name": "flashcards_by_c13u",
  "version": "1.0.0",
  "description": "A web application that helps me review content",
  "main": "dist/App.js",
  "nyc": {
    "reporter": [
      "lcov",
      "text"
    ],
    "exclude": [
      "tests",
      "build",
      "dist",
      "coverage",
      "node_modules",
      "src/models/mongoose_models"
    ],
    "include": [
      "src/models",
      "src/views",
      "src/controllers"
    ]
  },
  "scripts": {
    "prebuild_disabled": "tslint -c tslint.json -p tsconfig.json",
    "copy_assets": "cp -a src/public/css/. dist/public/css/ && cp -a src/public/images/. dist/public/images/ && cp -a src/views/. dist/views/",
    "build": "webpack --config src/webpack.config.js",
    "transpile": "tsc",
    "start": "tsc && node dist/App.js",
    "debug": "tsc && nodemon --inspect=127.0.0.1:9229 dist/App.js",
    "test": "nyc mocha --require ts-node/register --require source-map-support/register --file src/TestConfig.ts --exit --timeout 40000 'src/**/*Test.ts'",
    "heroku-postbuild": "echo Skip build on Heroku",
    "docs": "jsdoc -c ./config.jsdoc.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dchege711/study_buddy.git"
  },
  "keywords": [
    "study",
    "flashcards"
  ],
  "author": "Chege Gitau",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/dchege711/study_buddy/issues"
  },
  "homepage": "https://github.com/dchege711/study_buddy#readme",
  "dependencies": {
    "body-parser": "1.18.2",
    "cookie-parser": "^1.4.5",
    "ejs": "2.6.1",
    "express": "4.16.3",
    "express-session": "1.15.6",
    "express-sslify": "^1.2.0",
    "nodemailer": "^4.7.0",
    "path": "0.12.7",
    "pg": "^7.18.2",
    "pg-hstore": "^2.3.3",
    "sequelize": "^5.22.3",
    "sequelize-cli": "^5.5.1",
    "showdown": "^1.9.1",
    "sjcl": "1.0.7",
    "validator": "^10.11.0",
    "xss": "1.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.12.3",
    "@istanbuljs/nyc-config-typescript": "^0.1.3",
    "@types/bluebird": "^3.5.32",
    "@types/cookie-parser": "^1.4.2",
    "@types/express-session": "^1.17.0",
    "@types/express-sslify": "^1.2.1",
    "@types/mocha": "^5.2.7",
    "@types/node": "^12.19.1",
    "@types/nodemailer": "^6.4.0",
    "@types/sequelize": "^4.28.9",
    "@types/showdown": "^1.9.3",
    "@types/sjcl": "^1.0.29",
    "@types/supertest": "^2.0.10",
    "@types/validator": "^10.11.3",
    "acorn": "^7.4.1",
    "babel": "^6.23.0",
    "babel-loader": "^8.1.0",
    "circular-dependency-plugin": "^5.2.0",
    "clean-webpack-plugin": "^0.1.19",
    "highlightjs": "^9.16.2",
    "jsdoc": "^3.6.6",
    "mathjax": "^2.7.9",
    "mocha": "^8.2.0",
    "node-mocks-http": "^1.9.0",
    "nodemon": "^2.0.6",
    "nyc": "^14.1.1",
    "selenium-webdriver": "4.0.0-alpha.1",
    "source-map-support": "^0.5.19",
    "supertest": "^4.0.2",
    "ts-node": "^8.10.2",
    "tslint": "^5.20.1",
    "typescript": "^3.9.7",
    "webpack": "^4.44.2",
    "webpack-cli": "^4.1.0",
    "why-is-node-running": "2.0.2"
  },
  "heroku-run-build-script": true
}
