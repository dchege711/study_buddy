{
    "extends": "@istanbuljs/nyc-config-typescript",
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/**/*Test.ts"
    ], 

    "check-coverage": true, 
    "branches": 80,
    "lines": 80,
    "functions": 80,
    "statements": 80, 

    "report-dir": "coverage", 
    "reporter": "lcov"
}